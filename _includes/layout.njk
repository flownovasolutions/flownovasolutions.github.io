<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="google-site-verification" content="UhtLBVhPlP8xSaH719TKY_co4f8IYrm9BpNr3LoTfrA" />
  <title>{{ title }}</title>

  <link rel="stylesheet" href="/css/global.css">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}

  {# ——— CANONICAL URL ——— #}
  <link rel="canonical" href="https://flownovasolutions.com{{ page.url }}">

  {# ——— OPEN GRAPH ——— #}
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="FlowNova Solutions">
  <meta property="og:title" content="{{ title | default('FlowNova Solutions — Process Improvement & Automation') }}">
  <meta property="og:description" content="{{ description | default('FlowNova builds modern systems that help teams move faster, work smarter, and scale with confidence. Based in Tulsa, OK — serving clients nationwide.') }}">
  <meta property="og:url" content="https://flownovasolutions.com{{ page.url }}">
  <meta property="og:image" content="{{ ogImage | default('https://flownovasolutions.com/images/og-default.png') }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="en_US">

  {# ——— TWITTER / X CARD ——— #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title | default('FlowNova Solutions — Process Improvement & Automation') }}">
  <meta name="twitter:description" content="{{ description | default('FlowNova builds modern systems that help teams move faster, work smarter, and scale with confidence.') }}">
  <meta name="twitter:image" content="{{ ogImage | default('https://flownovasolutions.com/images/og-default.png') }}">

  {# ——— STRUCTURED DATA (JSON-LD) ——— #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "FlowNova Solutions",
    "description": "Process improvement and business automation consulting powered by Microsoft Power Platform. Based in Tulsa, OK, serving clients nationwide.",
    "url": "https://flownovasolutions.com",
    "telephone": "+19182609589",
    "founder": {
      "@type": "Person",
      "name": "Shelby Williams"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Tulsa",
      "addressRegion": "OK",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "Country",
      "name": "United States"
    },
    "serviceType": [
      "Process Mapping & Improvement",
      "Business Process Automation",
      "Custom App Development",
      "Power Platform Consulting",
      "AI & Copilot Integration",
      "Dataverse Schema Design",
      "Power BI Reporting & Dashboards",
      "SharePoint Integration & Automation"
    ],
    "knowsAbout": [
      "Microsoft Power Platform",
      "Power Apps",
      "Power Automate",
      "Dataverse",
      "Power BI",
      "Copilot Studio",
      "Microsoft Graph API",
      "SharePoint"
    ],
    "priceRange": "$$",
    "sameAs": [
      "https://www.linkedin.com/company/flownovasolutions"
    ]
  }
  </script>

</head>

<body>

  {# GLOBAL SVG SPRITE #}
  {% include "global/svg-sprite.html" %}

  {# GLOBAL HEADER #}
  {% include "global/header.html" %}

  {# PAGE CONTENT #}
  {{ content | safe }}

  {# GLOBAL FOOTER #}
  {% include "global/footer.html" %}

</body>
</html>
